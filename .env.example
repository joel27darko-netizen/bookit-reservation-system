# Copy this file to .env and adjust values for your environment.

APP_NAME=BookIt - Reservation Management System
ENV=development

# SQLite for dev; swap for PostgreSQL in production, e.g.:
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/bookit
DATABASE_URL=sqlite:///./bookit.db

# IMPORTANT: change this in any real deployment
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_super_secret_key_please_rotate
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720
COOKIE_NAME=bookit_access_token

DEFAULT_SLOT_MINUTES=30
CANCELLATION_WINDOW_HOURS=2
